// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Define your database schema here

model User {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(50)
  email          String    @unique @db.VarChar(50)
  password       String    @db.VarChar(100)
  trackClerkId   String    @unique @map("track_clerk_id") @db.VarChar(255)
  dateOfBirth    DateTime? @map("date_of_birth") @db.Date
  image          String?   @db.VarChar(255)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  playlists         Playlist[]
  followers         Follower[]
  likes             Like[]
  podcastFollowers  PodcastFollower[]
  listeningHistory  ListeningHistory[]

  @@map("users")
}

model Artist {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  bio       String?
  image     String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  albums       Album[]
  tracks       Track[]       @relation("PrimaryArtist")
  trackArtists TrackArtist[]
  followers    Follower[]

  @@map("artists")
}

model Album {
  id        Int      @id @default(autoincrement())
  artistId  Int?     @map("artist_id")
  name      String   @db.VarChar(50)
  image     String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  artist Artist? @relation(fields: [artistId], references: [id], onDelete: SetNull)

  tracks      Track[]
  albumGenres AlbumGenre[]

  @@index([artistId])
  @@map("albums")
}

model Track {
  id         Int      @id @default(autoincrement())
  albumId    Int?     @map("album_id")
  artistId   Int      @map("artist_id") // Primary artist
  name       String   @db.VarChar(50)
  trackNumber Int      @map("track_number") // Essential for sorting
  discNumber  Int      @default(1) @map("disc_number") // For multi-disc albums
  duration   Int
  path       String?  @db.VarChar(255)
  image      String?  @db.VarChar(255)
  isExplicit Boolean  @default(false) @map("is_explicit")
  playCount  Int      @default(0) @map("play_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  album  Album?  @relation(fields: [albumId], references: [id], onDelete: SetNull)
  artist Artist  @relation("PrimaryArtist", fields: [artistId], references: [id], onDelete: Cascade)

  trackArtists     TrackArtist[]
  playlistTracks   PlaylistTrack[]
  likes            Like[]
  trackGenres      TrackGenre[]
  listeningHistory ListeningHistory[]

  @@index([albumId])
  @@index([artistId])
  @@map("tracks")
}

model TrackArtist {
  trackId    Int    @map("track_id")
  artistId   Int    @map("artist_id")
  artistRole String @map("artist_role") @db.VarChar(50) // e.g., featured, producer, composer

  track  Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([trackId, artistId, artistRole])
  @@map("track_artists")
}

model Playlist {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  name      String   @db.VarChar(50)
  image     String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  playlistTracks PlaylistTrack[]

  @@index([userId])
  @@map("playlists")
}

model PlaylistTrack {
  playlistId Int      @map("playlist_id")
  trackId    Int      @map("track_id")
  trackOrder Int?     @map("track_order")
  addedAt    DateTime @default(now()) @map("added_at")

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@id([playlistId, trackId])
  @@map("playlist_tracks")
}

model Follower {
  userId   Int @map("user_id")
  artistId Int @map("artist_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([userId, artistId])
  @@map("followers")
}

model Like {
  userId       Int      @map("user_id")
  trackId      Int      @map("track_id")
  likeDateTime DateTime? @map("like_date_time")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@id([userId, trackId])
  @@map("likes")
}

model Genre {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  trackGenres TrackGenre[]
  albumGenres AlbumGenre[]

  @@index([name])
  @@map("genres")
}

model TrackGenre {
  trackId Int @map("track_id")
  genreId Int @map("genre_id")

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([trackId, genreId])
  @@map("track_genres")
}

model AlbumGenre {
  albumId Int @map("album_id")
  genreId Int @map("genre_id")

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([albumId, genreId])
  @@map("album_genres")
}

model Podcast {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(100)
  hostName    String?  @map("host_name") @db.VarChar(100)
  description String?
  coverImage  String?  @map("cover_image") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  episodes         Episode[]
  podcastFollowers PodcastFollower[]

  @@map("podcasts")
}

model Episode {
  id          Int       @id @default(autoincrement())
  podcastId   Int?      @map("podcast_id")
  title       String    @db.VarChar(100)
  description String?
  duration    Int?
  audioPath   String?   @map("audio_path") @db.VarChar(255)
  releaseDate DateTime? @map("release_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  podcast Podcast? @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  listeningHistory ListeningHistory[]

  @@index([podcastId])
  @@map("episodes")
}

model PodcastFollower {
  userId     Int      @map("user_id")
  podcastId  Int      @map("podcast_id")
  followedAt DateTime @default(now()) @map("followed_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@id([userId, podcastId])
  @@map("podcast_followers")
}

model ListeningHistory {
  id              Int      @id @default(autoincrement())
  userId          Int?     @map("user_id")
  trackId         Int?     @map("track_id") // Nullable: Filled if listening to a song
  episodeId       Int?     @map("episode_id") // Nullable: Filled if listening to a podcast
  progressSeconds Int?     @map("progress_seconds") // Where the user left off
  isCompleted     Boolean  @default(false) @map("is_completed")
  lastPlayedAt    DateTime @default(now()) @map("last_played_at")
  createdAt       DateTime @default(now()) @map("created_at")

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  track   Track?   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  episode Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([trackId])
  @@index([episodeId])
  @@map("listening_history")
}